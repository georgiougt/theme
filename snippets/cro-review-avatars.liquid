{% comment %}
  Trustpilot Review Avatars Social Proof (Shrine Pro Feature)
  ConvertStudio Theme
{% endcomment %}

<div class="cro-review-avatars">
  <div class="cro-ra__avatars">
    <img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=100&auto=format&fit=crop&q=80" alt="Customer Avatar" class="cro-ra__avatar">
    <img src="https://images.unsplash.com/photo-1517841905240-472988babdf9?w=100&auto=format&fit=crop&q=80" alt="Customer Avatar" class="cro-ra__avatar">
    <img src="https://images.unsplash.com/photo-1539571696357-5a69c17a67c6?w=100&auto=format&fit=crop&q=80" alt="Customer Avatar" class="cro-ra__avatar">
    <img src="https://images.unsplash.com/photo-1524504388940-b1c1722653e1?w=100&auto=format&fit=crop&q=80" alt="Customer Avatar" class="cro-ra__avatar">
  </div>

  <div class="cro-ra__info">
    <div class="cro-ra__stars">
      <span class="cro-ra__star">★</span>
      <span class="cro-ra__star">★</span>
      <span class="cro-ra__star">★</span>
      <span class="cro-ra__star">★</span>
      <span class="cro-ra__star">★</span>
      <span class="cro-ra__rating">4.9 / 5.0</span>
    </div>
    <span class="cro-ra__text">Rated Excellent by <strong>2,480+ Verified Buyers</strong></span>
  </div>
</div>

<style>
  .cro-review-avatars {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-block: 1rem;
    padding: 0.65rem 1rem;
    background: #f8fafc;
    border-radius: 50px;
    width: fit-content;
    border: 1px solid #e2e8f0;
  }

  .cro-ra__avatars {
    display: flex;
    align-items: center;
  }

  .cro-ra__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 2px solid #ffffff;
    object-fit: cover;
    margin-left: -10px;
  }

  .cro-ra__avatar:first-child {
    margin-left: 0;
  }

  .cro-ra__info {
    display: flex;
    flex-direction: column;
  }

  .cro-ra__stars {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .cro-ra__star {
    color: #00b67a; /* Trustpilot Green */
    font-size: 0.9375rem;
  }

  .cro-ra__rating {
    font-size: 0.775rem;
    font-weight: 800;
    color: #0f172a;
    margin-left: 0.35rem;
  }

  .cro-ra__text {
    font-size: 0.75rem;
    color: #475569;
  }
</style>
