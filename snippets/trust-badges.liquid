{% comment %}
  Renders Trust Badges and Secure Payment Icons
  Usage: {% render 'trust-badges', context: 'drawer' %}
{% endcomment %}

{%- if settings.trust_badges_enable -%}
  <div class="cro-trust-badges cro-trust-badges--{{ context | default: 'default' }}">
    <div class="cro-trust-badges__grid">
      {%- if settings.trust_badge_1_text != blank -%}
        <div class="cro-trust-badges__item">
          <svg class="cro-trust-badges__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="1" y="3" width="15" height="13"></rect>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
            <circle cx="5.5" cy="18.5" r="2.5"></circle>
            <circle cx="18.5" cy="18.5" r="2.5"></circle>
          </svg>
          <span class="cro-trust-badges__text">{{ settings.trust_badge_1_text }}</span>
        </div>
      {%- endif -%}

      {%- if settings.trust_badge_2_text != blank -%}
        <div class="cro-trust-badges__item">
          <svg class="cro-trust-badges__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
          <span class="cro-trust-badges__text">{{ settings.trust_badge_2_text }}</span>
        </div>
      {%- endif -%}

      {%- if settings.trust_badge_3_text != blank -%}
        <div class="cro-trust-badges__item">
          <svg class="cro-trust-badges__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
          <span class="cro-trust-badges__text">{{ settings.trust_badge_3_text }}</span>
        </div>
      {%- endif -%}

      {%- if settings.trust_badge_4_text != blank -%}
        <div class="cro-trust-badges__item">
          <svg class="cro-trust-badges__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
          </svg>
          <span class="cro-trust-badges__text">{{ settings.trust_badge_4_text }}</span>
        </div>
      {%- endif -%}
    </div>

    {%- if settings.show_payment_icons -%}
      <div class="cro-trust-badges__payments">
        <span class="cro-trust-badges__payments-label">Guaranteed Safe Checkout</span>
        <div class="cro-trust-badges__payment-list">
          {%- assign enabled_payment_types = 'visa,master,american_express,paypal,apple_pay,google_pay,shopify_pay' | split: ',' -%}
          {%- for type in enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'cro-trust-badges__payment-icon' }}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>

  <style>
    .cro-trust-badges {
      padding-block: 0.75rem;
      border-top: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
      width: 100%;
    }

    .cro-trust-badges__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.5rem;
      margin-bottom: 0.75rem;
    }

    .cro-trust-badges__item {
      display: flex;
      align-items: center;
      gap: 0.35rem;
    }

    .cro-trust-badges__icon {
      width: 16px;
      height: 16px;
      flex-shrink: 0;
      color: var(--color-foreground, #0f172a);
    }

    .cro-trust-badges__text {
      font-size: 0.6875rem;
      font-weight: 600;
      color: var(--color-foreground, #334155);
      line-height: 1.2;
    }

    .cro-trust-badges__payments {
      text-align: center;
      margin-top: 0.5rem;
    }

    .cro-trust-badges__payments-label {
      display: block;
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-foreground, #64748b);
      margin-bottom: 0.35rem;
    }

    .cro-trust-badges__payment-list {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 0.35rem;
    }

    .cro-trust-badges__payment-icon {
      height: 20px;
      width: auto;
    }
  </style>
{%- endif -%}
