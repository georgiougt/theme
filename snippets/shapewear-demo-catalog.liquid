<style>
  .shapewear-demo-catalog {
    padding-block: 2.5rem;
    max-width: 1280px;
    margin: 0 auto;
    padding-inline: 1.5rem;
  }

  .shapewear-demo-catalog__header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .shapewear-demo-catalog__heading {
    font-family: 'Hunter', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }

  .shapewear-demo-catalog__subheading {
    font-size: 0.95rem;
    color: #64748b;
    max-width: 600px;
    margin: 0 auto;
  }

  .shapewear-demo-catalog__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .shapewear-card {
    position: relative;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .shapewear-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
  }

  .shapewear-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    padding: 0.25rem 0.65rem;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: 9999px;
    color: #ffffff;
    background: #0f172a;
  }

  .shapewear-card__badge--bestseller { background: #ef4444; }
  .shapewear-card__badge--trending { background: #8b5cf6; }
  .shapewear-card__badge--firm { background: #0284c7; }
  .shapewear-card__badge--lift { background: #ec4899; }

  .shapewear-card__media {
    width: 100%;
    aspect-ratio: 4/5;
    overflow: hidden;
    background: #f8fafc;
  }

  .shapewear-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .shapewear-card:hover .shapewear-card__media img {
    transform: scale(1.05);
  }

  .shapewear-card__info {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.4rem;
  }

  .shapewear-card__rating {
    font-size: 0.75rem;
    color: #f59e0b;
  }

  .shapewear-card__rating span {
    color: #64748b;
  }

  .shapewear-card__title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0;
    line-height: 1.3;
  }

  .shapewear-card__price {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
  }

  .shapewear-card__price-current {
    font-weight: 700;
    color: #0f172a;
  }

  .shapewear-card__price-compare {
    text-decoration: line-through;
    color: #94a3b8;
    font-size: 0.8125rem;
  }

  .shapewear-card__price-save {
    font-size: 0.6875rem;
    font-weight: 700;
    color: #16a34a;
    background: #dcfce7;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
  }

  .shapewear-card__btn {
    margin-top: auto;
    padding: 0.6rem;
    width: 100%;
    background: #0f172a;
    color: #ffffff;
    border: none;
    border-radius: 6px;
    font-size: 0.8125rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .shapewear-card__btn:hover {
    background: #1e293b;
  }
</style>
