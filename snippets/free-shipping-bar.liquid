{% comment %}
  Renders dynamic Free Shipping Progress Bar Web Component
  Usage: {% render 'free-shipping-bar' %}
{% endcomment %}

{%- if settings.free_shipping_enable -%}
  {%- liquid
    assign threshold = settings.free_shipping_threshold | times: 100
    assign cart_total = cart.total_price
    assign remaining = threshold | minus: cart_total
    
    if remaining <= 0
      assign progress_percentage = 100
      assign is_unlocked = true
    else
      assign progress_percentage = cart_total | times: 100 | divided_by: threshold
      assign is_unlocked = false
    endif
  -%}

  <free-shipping-bar
    class="free-shipping-bar"
    data-threshold="{{ threshold }}"
    data-cart-total="{{ cart_total }}"
    data-initial-message="{{ settings.free_shipping_message_initial | escape }}"
    data-success-message="{{ settings.free_shipping_message_success | escape }}"
  >
    <div class="free-shipping-bar__container">
      <div class="free-shipping-bar__message" data-message-target>
        {%- if is_unlocked -%}
          {{ settings.free_shipping_message_success }}
        {%- else -%}
          {%- assign remaining_formatted = remaining | money -%}
          {{ settings.free_shipping_message_initial | replace: '[amount]', remaining_formatted }}
        {%- endif -%}
      </div>
      <div class="free-shipping-bar__track">
        <div
          class="free-shipping-bar__progress"
          style="width: {{ progress_percentage }}%; background-color: {{ settings.free_shipping_bar_color | default: '#10b981' }};"
          data-progress-target
        ></div>
      </div>
    </div>
  </free-shipping-bar>

  <style>
    .free-shipping-bar {
      display: block;
      padding: 1rem 1.25rem;
      background-color: var(--color-background-secondary, #f8fafc);
      border-bottom: 1px solid rgb(var(--color-foreground-rgb, 0 0 0) / 0.1);
      width: 100%;
    }
    .free-shipping-bar__container {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .free-shipping-bar__message {
      font-size: 0.875rem;
      font-weight: 600;
      text-align: center;
      color: var(--color-foreground, #1e293b);
    }
    .free-shipping-bar__track {
      width: 100%;
      height: 8px;
      background-color: rgba(0, 0, 0, 0.1);
      border-radius: 9999px;
      overflow: hidden;
    }
    .free-shipping-bar__progress {
      height: 100%;
      border-radius: 9999px;
      transition: width 0.4s ease-in-out, background-color 0.3s ease;
    }
  </style>

  <script>
    if (!customElements.get('free-shipping-bar')) {
      customElements.define(
        'free-shipping-bar',
        class FreeShippingBar extends HTMLElement {
          constructor() {
            super();
            this.threshold = parseInt(this.dataset.threshold || '0', 10);
            this.initialMsg = this.dataset.initialMessage || '';
            this.successMsg = this.dataset.successMessage || '';
            this.messageEl = this.querySelector('[data-message-target]');
            this.progressEl = this.querySelector('[data-progress-target]');
          }

          connectedCallback() {
            document.addEventListener('cart:updated', this.handleCartChange.bind(this));
          }

          disconnectedCallback() {
            document.removeEventListener('cart:updated', this.handleCartChange.bind(this));
          }

          handleCartChange(event) {
            if (!event.detail || !event.detail.cart) return;
            this.updateState(event.detail.cart.total_price);
          }

          updateState(cartTotal) {
            const threshold = this.threshold;
            if (!threshold) return;

            const remaining = threshold - cartTotal;
            let percentage = 0;

            if (remaining <= 0) {
              percentage = 100;
              if (this.messageEl) this.messageEl.textContent = this.successMsg;
            } else {
              percentage = Math.min(100, Math.max(0, (cartTotal / threshold) * 100));
              const formattedRemaining = this.formatMoney(remaining);
              if (this.messageEl) {
                this.messageEl.textContent = this.initialMsg.replace('[amount]', formattedRemaining);
              }
            }

            if (this.progressEl) {
              this.progressEl.style.width = `${percentage}%`;
            }
          }

          formatMoney(cents) {
            if (typeof Shopify !== 'undefined' && Shopify.formatMoney) {
              return Shopify.formatMoney(cents);
            }
            const dollars = (cents / 100).toFixed(2);
            return `$${dollars}`;
          }
        }
      );
    }
  </script>
{%- endif -%}
