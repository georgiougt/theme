{% comment %}
  Before & After Image Comparison Slider (Shrine Pro Feature)
  ConvertStudio Theme
{% endcomment %}

<div class="before-after-section page-width color-custom-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <div class="ba-header text-center">
      <span class="ba-tagline">{{ section.settings.subheading | default: "REAL VISIBLE RESULTS" }}</span>
      <h2 class="ba-title">{{ section.settings.heading }}</h2>
      <p class="ba-description">{{ section.settings.description }}</p>
    </div>
  {%- endif -%}

  <div class="ba-container" data-ba-container>
    <!-- Before Image -->
    <div class="ba-image ba-image--before">
      <img src="{{ section.settings.before_image | image_url: width: 1200 | default: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=1000' }}" alt="Before Shapewear" loading="lazy">
      <span class="ba-label ba-label--before">{{ section.settings.before_label | default: "BEFORE" }}</span>
    </div>

    <!-- After Image -->
    <div class="ba-image ba-image--after" data-ba-after>
      <img src="{{ section.settings.after_image | image_url: width: 1200 | default: 'https://images.unsplash.com/photo-1539109136881-3be0616acf4b?w=1000' }}" alt="After Shapewear" loading="lazy">
      <span class="ba-label ba-label--after">{{ section.settings.after_label | default: "AFTER CONVERTSTUDIO" }}</span>
    </div>

    <!-- Drag Divider Handle -->
    <div class="ba-handle" data-ba-handle>
      <div class="ba-handle-line"></div>
      <div class="ba-handle-circle">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="m9 18-6-6 6-6"/><path d="m15 6 6 6-6 6"/>
        </svg>
      </div>
      <div class="ba-handle-line"></div>
    </div>

    <!-- Range Input Overlay -->
    <input type="range" min="0" max="100" value="50" class="ba-range" data-ba-range aria-label="Before and After slider">
  </div>
</div>

<style>
  .before-after-section {
    padding-block: 4rem;
  }

  .ba-header {
    text-align: center;
    max-width: 650px;
    margin: 0 auto 2.5rem auto;
  }

  .ba-tagline {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #38bdf8;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .ba-title {
    font-family: 'Hunter', sans-serif !important;
    font-size: clamp(1.8rem, 4vw, 2.75rem);
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.75rem;
  }

  .ba-description {
    font-size: 1rem;
    color: #64748b;
  }

  .ba-container {
    position: relative;
    width: 100%;
    max-width: 900px;
    height: 550px;
    margin: 0 auto;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 15px 40px rgba(15, 23, 42, 0.15);
    user-select: none;
  }

  @media screen and (max-width: 749px) {
    .ba-container {
      height: 380px;
    }
  }

  .ba-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .ba-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .ba-image--after {
    width: 50%;
    overflow: hidden;
    border-right: 2px solid #ffffff;
  }

  .ba-label {
    position: absolute;
    bottom: 20px;
    padding: 0.4rem 1rem;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 50px;
    color: #ffffff;
    z-index: 5;
  }

  .ba-label--before {
    left: 20px;
    background: rgba(15, 23, 42, 0.75);
    backdrop-filter: blur(4px);
  }

  .ba-label--after {
    right: 20px;
    background: #10b981;
    box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);
  }

  .ba-handle {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    z-index: 10;
    pointer-events: none;
  }

  .ba-handle-line {
    width: 3px;
    flex-grow: 1;
    background: #ffffff;
    box-shadow: 0 0 8px rgba(0, 0, 0, 0.3);
  }

  .ba-handle-circle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #0f172a;
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    border: 3px solid #ffffff;
  }

  .ba-range {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: ew-resize;
    z-index: 20;
    margin: 0;
  }
</style>

<script>
  (function () {
    document.addEventListener('input', function (e) {
      if (e.target && e.target.matches('[data-ba-range]')) {
        const container = e.target.closest('[data-ba-container]');
        if (!container) return;

        const val = e.target.value;
        const afterImg = container.querySelector('[data-ba-after]');
        const handle = container.querySelector('[data-ba-handle]');

        if (afterImg) afterImg.style.width = val + '%';
        if (handle) handle.style.left = val + '%';
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Gaia: Before & After",
  "tag": "section",
  "class": "section-before-after",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "REAL VISIBLE RESULTS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Instant -3 Inches Waist Contouring"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Drag the slider to see how ConvertStudio medical-grade shapewear smooths curves and Sculpts your silhouette under any outfit."
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before Image"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Before Label",
      "default": "BEFORE"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After Image"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "After Label",
      "default": "AFTER CONVERTSTUDIO"
    }
  ],
  "presets": [
    {
      "name": "Gaia: Before & After"
    }
  ]
}
{% endschema %}
