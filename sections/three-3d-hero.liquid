{% comment %}
  Gaia 3D Visual Effects Hero Section
  ConvertStudio Theme
{% endcomment %}

<script src="{{ 'three-hero.js' | asset_url }}" defer="defer"></script>

<div class="three-hero-section color-custom-{{ section.id }}" style="
  min-height: {{ section.settings.section_height | default: '85vh' }};
  background: linear-gradient(135deg, {{ section.settings.bg_gradient_start | default: '#0f172a' }} 0%, {{ section.settings.bg_gradient_end | default: '#1e1b4b' }} 100%);
">
  <three-hero-canvas
    class="three-hero-canvas"
    data-animation="{{ section.settings.animation_type | default: 'wave_field' }}"
    data-primary-color="{{ section.settings.primary_color | default: '#38bdf8' }}"
    data-accent-color="{{ section.settings.accent_color | default: '#818cf8' }}"
    data-wireframe="{{ section.settings.wireframe_mode }}"
    data-speed="{{ section.settings.animation_speed | default: 5 }}"
    data-rotation="{{ section.settings.rotation_speed | default: 5 }}"
    data-parallax="{{ section.settings.enable_parallax }}"
  ></three-hero-canvas>

  <div class="three-hero-content page-width">
    {%- if section.settings.subheading != blank -%}
      <span class="three-hero-tagline" style="color: {{ section.settings.tagline_color | default: '#38bdf8' }};">
        {{- section.settings.subheading -}}
      </span>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="three-hero-title" style="color: {{ section.settings.heading_color | default: '#ffffff' }};">
        {{- section.settings.heading -}}
      </h1>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <p class="three-hero-description" style="color: {{ section.settings.text_color | default: '#cbd5e1' }};">
        {{- section.settings.text -}}
      </p>
    {%- endif -%}

    {%- if section.settings.button_label != blank -%}
      <a
        href="{{ section.settings.button_link | default: '/collections/all' }}"
        class="three-hero-button"
        style="
          background: {{ section.settings.button_bg | default: '#ffffff' }};
          color: {{ section.settings.button_text | default: '#0f172a' }};
        "
      >
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

<style>
  .three-hero-section {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .three-hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: auto;
  }

  .three-hero-canvas canvas {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }

  .three-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    padding-inline: 1.5rem;
    pointer-events: none;
  }

  .three-hero-content * {
    pointer-events: auto;
  }

  .three-hero-tagline {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    display: inline-block;
  }

  .three-hero-title {
    font-family: 'Hunter', sans-serif !important;
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .three-hero-description {
    font-size: 1.1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .three-hero-button {
    display: inline-block;
    padding: 0.85rem 2.25rem;
    font-family: 'Hunter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    border-radius: 50px;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s ease;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
  }

  .three-hero-button:hover {
    transform: translateY(-2px);
    opacity: 0.9;
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.35);
  }
</style>

{% schema %}
{
  "name": "Gaia: 3D Hero",
  "tag": "section",
  "class": "section-3d-hero",
  "settings": [
    {
      "type": "header",
      "content": "3D Animation Settings"
    },
    {
      "type": "select",
      "id": "animation_type",
      "label": "3D Animation Preset",
      "options": [
        { "value": "wave_field", "label": "1. Dynamic Wave Field" },
        { "value": "torus_knot", "label": "2. Sculpted Torus Knot" },
        { "value": "icosahedron", "label": "3. Floating Crystal Mesh" },
        { "value": "galaxy_orbs", "label": "4. Cosmic Galaxy Orbs" },
        { "value": "dna_helix", "label": "5. DNA Double Helix" },
        { "value": "cyber_ring", "label": "6. Pulsing Cyber Rings" },
        { "value": "hyper_sphere", "label": "7. Deforming Hyper-Sphere" },
        { "value": "particle_tunnel", "label": "8. Warp Speed Tunnel" },
        { "value": "cube_matrix", "label": "9. Wireframe Cube Matrix" },
        { "value": "diamond_grid", "label": "10. Diamond Lattice Grid" }
      ],
      "default": "wave_field"
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation Movement Speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "label": "3D Object Rotation Speed",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "wireframe_mode",
      "label": "Enable Wireframe / Glow Mesh",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_parallax",
      "label": "Enable Interactive Mouse Parallax",
      "default": true
    },
    {
      "type": "header",
      "content": "Color Customization"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "3D Object Main Color",
      "default": "#38bdf8"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "3D Accent / Glow Color",
      "default": "#818cf8"
    },
    {
      "type": "color",
      "id": "bg_gradient_start",
      "label": "Background Gradient Start",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "bg_gradient_end",
      "label": "Background Gradient End",
      "default": "#1e1b4b"
    },
    {
      "type": "header",
      "content": "Content & Typography"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading / Tagline",
      "default": "INTERACTIVE 3D EXPERIENCE"
    },
    {
      "type": "color",
      "id": "tagline_color",
      "label": "Tagline Color",
      "default": "#38bdf8"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NEXT-GEN 3D BODY SCULPTING"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description Text",
      "default": "Experience 360° targeted waist compression & seamless contouring with medical-grade precision."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description Text Color",
      "default": "#cbd5e1"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "DISCOVER 3D COLLECTION"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button Text Color",
      "default": "#0f172a"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section Height",
      "options": [
        { "value": "60vh", "label": "Compact (60vh)" },
        { "value": "75vh", "label": "Medium (75vh)" },
        { "value": "85vh", "label": "Tall (85vh)" },
        { "value": "100vh", "label": "Full Screen (100vh)" }
      ],
      "default": "85vh"
    }
  ],
  "presets": [
    {
      "name": "Gaia: 3D Hero"
    }
  ]
}
{% endschema %}
