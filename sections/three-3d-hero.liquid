{% comment %}
  Three.js 3D Visual Effects Hero Section
{% endcomment %}

<script src="{{ 'three-hero.js' | asset_url }}" defer="defer"></script>

<div class="three-hero-section color-custom-{{ section.id }}">
  <three-hero-canvas class="three-hero-canvas"></three-hero-canvas>

  <div class="three-hero-content page-width">
    <span class="three-hero-tagline">{{ section.settings.subheading | default: "INTERACTIVE 3D EXPERIENCE" }}</span>
    <h1 class="three-hero-title">{{ section.settings.heading | default: "NEXT-GEN 3D BODY SCULPTING" }}</h1>
    <p class="three-hero-description">{{ section.settings.text | default: "Experience 360° targeted waist compression & seamless contouring with medical-grade precision." }}</p>

    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="three-hero-button">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

<style>
  .three-hero-section {
    position: relative;
    width: 100%;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
    color: #ffffff;
  }

  .three-hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: auto;
  }

  .three-hero-canvas canvas {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }

  .three-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    padding-inline: 1.5rem;
    pointer-events: none;
  }

  .three-hero-content * {
    pointer-events: auto;
  }

  .three-hero-tagline {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #38bdf8;
    margin-bottom: 0.75rem;
    display: inline-block;
  }

  .three-hero-title {
    font-family: 'Hunter', sans-serif !important;
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1rem;
    color: #ffffff;
  }

  .three-hero-description {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #cbd5e1;
    margin-bottom: 2rem;
  }

  .three-hero-button {
    display: inline-block;
    padding: 0.85rem 2.25rem;
    font-family: 'Hunter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #0f172a;
    background: #ffffff;
    border-radius: 50px;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    box-shadow: 0 10px 25px rgba(56, 189, 248, 0.3);
  }

  .three-hero-button:hover {
    transform: translateY(-2px);
    background: #38bdf8;
    color: #ffffff;
    box-shadow: 0 14px 30px rgba(56, 189, 248, 0.5);
  }
</style>

{% schema %}
{
  "name": "ConvertStudio: 3D Hero Canvas (Three.js)",
  "tag": "section",
  "class": "section-3d-hero",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Tagline",
      "default": "INTERACTIVE 3D EXPERIENCE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NEXT-GEN 3D BODY SCULPTING"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Experience 360° targeted waist compression & seamless contouring with medical-grade precision."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "DISCOVER 3D COLLECTION"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "ConvertStudio: 3D Hero Canvas (Three.js)"
    }
  ]
}
{% endschema %}
