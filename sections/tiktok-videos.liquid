{% comment %}
  TikTok UGC Video Carousel (Shrine Pro Feature)
  ConvertStudio Theme
{% endcomment %}

<div class="tiktok-videos-section page-width color-custom-{{ section.id }}">
  <div class="tv-header text-center">
    <span class="tv-tagline">{{ section.settings.subheading | default: "VIRAL ON TIKTOK" }}</span>
    <h2 class="tv-title">{{ section.settings.heading | default: "50,000+ WOMEN CAN'T BE WRONG" }}</h2>
  </div>

  <div class="tv-grid">
    <!-- UGC Card 1 -->
    <div class="tv-card">
      <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=600" alt="TikTok UGC" class="tv-img">
      <div class="tv-overlay">
        <span class="tv-handle">@sophia_fits</span>
        <p class="tv-quote">"Literally snatched my waist in seconds! 😱 Best shapewear ever."</p>
      </div>
    </div>

    <!-- UGC Card 2 -->
    <div class="tv-card">
      <img src="https://images.unsplash.com/photo-1539109136881-3be0616acf4b?w=600" alt="TikTok UGC" class="tv-img">
      <div class="tv-overlay">
        <span class="tv-handle">@emma_glam</span>
        <p class="tv-quote">"Fits under my tightest dress with ZERO lines visible! 🔥"</p>
      </div>
    </div>

    <!-- UGC Card 3 -->
    <div class="tv-card">
      <img src="https://images.unsplash.com/photo-1578632767115-351597cf2477?w=600" alt="TikTok UGC" class="tv-img">
      <div class="tv-overlay">
        <span class="tv-handle">@chloe_style</span>
        <p class="tv-quote">"Doesn't roll down at all! I wore it for 12 hrs comfortably."</p>
      </div>
    </div>

    <!-- UGC Card 4 -->
    <div class="tv-card">
      <img src="https://images.unsplash.com/photo-1524504388940-b1c1722653e1?w=600" alt="TikTok UGC" class="tv-img">
      <div class="tv-overlay">
        <span class="tv-handle">@mia_beauty</span>
        <p class="tv-quote">"Bought 3 pairs. Never going back to plain underwear!"</p>
      </div>
    </div>
  </div>
</div>

<style>
  .tiktok-videos-section {
    padding-block: 4rem;
  }

  .tv-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 2.5rem auto;
  }

  .tv-tagline {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #38bdf8;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .tv-title {
    font-family: 'Hunter', sans-serif !important;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #0f172a;
  }

  .tv-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  @media screen and (max-width: 989px) {
    .tv-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 480px) {
    .tv-grid {
      grid-template-columns: 1fr;
    }
  }

  .tv-card {
    position: relative;
    height: 420px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(15, 23, 42, 0.12);
  }

  .tv-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .tv-card:hover .tv-img {
    transform: scale(1.05);
  }

  .tv-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15, 23, 42, 0.9) 0%, transparent 60%);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: #ffffff;
  }

  .tv-handle {
    font-weight: 800;
    font-size: 0.85rem;
    color: #38bdf8;
    margin-bottom: 0.35rem;
  }

  .tv-quote {
    font-size: 0.85rem;
    line-height: 1.4;
    margin: 0;
  }
</style>

{% schema %}
{
  "name": "ConvertStudio: TikTok UGC Video Carousel",
  "tag": "section",
  "class": "section-tiktok-videos",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "VIRAL ON TIKTOK"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "50,000+ WOMEN CAN'T BE WRONG"
    }
  ],
  "presets": [
    {
      "name": "ConvertStudio: TikTok UGC Video Carousel"
    }
  ]
}
{% endschema %}
