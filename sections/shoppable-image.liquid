{% comment %}
  Shoppable Image Banner with Hotspot Pins (Shrine Pro Feature)
  ConvertStudio Theme
{% endcomment %}

<div class="shoppable-image-section page-width color-custom-{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <div class="si-header text-center">
      <span class="si-tagline">{{ section.settings.subheading | default: "TAP TO SHOP THE LOOK" }}</span>
      <h2 class="si-title">{{ section.settings.heading }}</h2>
    </div>
  {%- endif -%}

  <div class="si-banner">
    <img src="{{ section.settings.image | image_url: width: 1600 | default: 'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=1600' }}" alt="Shoppable Look" loading="lazy" class="si-banner-img">

    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <div class="si-pin" style="top: {{ block.settings.top_position }}%; left: {{ block.settings.left_position }}%;" {{ block.shopify_attributes }}>
          <button type="button" class="si-pin-btn" aria-label="View product">
            <span class="si-pin-pulse"></span>
            <span class="si-pin-icon">+</span>
          </button>

          <div class="si-popover">
            <div class="si-popover-title">{{ block.settings.title }}</div>
            <div class="si-popover-price">
              {{ block.settings.price }}
              {% if block.settings.compare_price != blank %}
                <span style="text-decoration:line-through;color:#94a3b8;font-size:0.75rem;">{{ block.settings.compare_price }}</span>
              {% endif %}
            </div>
            <a href="{{ block.settings.link | default: '/collections/all' }}" class="si-popover-btn">
              {{ block.settings.button_label | default: 'SHOP NOW' }}
            </a>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <!-- Default Pins -->
      <div class="si-pin" style="top: 35%; left: 45%;">
        <button type="button" class="si-pin-btn" aria-label="View product">
          <span class="si-pin-pulse"></span>
          <span class="si-pin-icon">+</span>
        </button>

        <div class="si-popover">
          <div class="si-popover-title">Full Body Hourglass Shaper</div>
          <div class="si-popover-price">$49.99 <span style="text-decoration:line-through;color:#94a3b8;font-size:0.75rem;">$89.99</span></div>
          <a href="/collections/all" class="si-popover-btn">SHOP NOW</a>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .shoppable-image-section {
    padding-block: 4rem;
  }

  .si-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 2.5rem auto;
  }

  .si-tagline {
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #38bdf8;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .si-title {
    font-family: 'Hunter', sans-serif !important;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #0f172a;
  }

  .si-banner {
    position: relative;
    width: 100%;
    max-height: 650px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 15px 40px rgba(15, 23, 42, 0.12);
  }

  .si-banner-img {
    width: 100%;
    height: 100%;
    max-height: 650px;
    object-fit: cover;
    display: block;
  }

  .si-pin {
    position: absolute;
    z-index: 10;
  }

  .si-pin-btn {
    position: relative;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #0f172a;
    color: #ffffff;
    border: 2px solid #ffffff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
    transition: transform 0.2s ease;
  }

  .si-pin-btn:hover {
    transform: scale(1.15);
  }

  .si-pin-icon {
    font-size: 1.2rem;
    font-weight: 700;
    line-height: 1;
  }

  .si-pin-pulse {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 2px solid #ffffff;
    animation: si-pulse-anim 2s infinite;
  }

  @keyframes si-pulse-anim {
    0% { transform: scale(0.9); opacity: 1; }
    100% { transform: scale(1.5); opacity: 0; }
  }

  .si-popover {
    position: absolute;
    bottom: 45px;
    left: 50%;
    transform: translateX(-50%);
    background: #ffffff;
    padding: 1rem;
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    width: 200px;
    text-align: center;
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s ease;
    pointer-events: none;
  }

  .si-pin:hover .si-popover {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    bottom: 50px;
  }

  .si-popover-title {
    font-weight: 700;
    font-size: 0.85rem;
    color: #0f172a;
    margin-bottom: 0.35rem;
  }

  .si-popover-price {
    font-weight: 800;
    font-size: 0.9rem;
    color: #0f172a;
    margin-bottom: 0.65rem;
  }

  .si-popover-btn {
    display: block;
    background: #0f172a;
    color: #ffffff;
    font-family: 'Hunter', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.4rem 0.85rem;
    border-radius: 6px;
    text-decoration: none;
  }
</style>

{% schema %}
{
  "name": "ConvertStudio: Shoppable Hotspot Banner",
  "tag": "section",
  "class": "section-shoppable-image",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "TAP TO SHOP THE LOOK"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "INSTAGRAM LIFESTYLE LOOKBOOK"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner Image"
    }
  ],
  "blocks": [
    {
      "type": "hotspot_pin",
      "name": "Hotspot Pin",
      "settings": [
        {
          "type": "range",
          "id": "top_position",
          "label": "Vertical Position Top (%)",
          "min": 5,
          "max": 95,
          "step": 1,
          "default": 35
        },
        {
          "type": "range",
          "id": "left_position",
          "label": "Horizontal Position Left (%)",
          "min": 5,
          "max": 95,
          "step": 1,
          "default": 45
        },
        {
          "type": "text",
          "id": "title",
          "label": "Product Title",
          "default": "Full Body Hourglass Shaper"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price",
          "default": "$49.99"
        },
        {
          "type": "text",
          "id": "compare_price",
          "label": "Compare at Price",
          "default": "$89.99"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Product / Collection Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ConvertStudio: Shoppable Hotspot Banner",
      "blocks": [
        {
          "type": "hotspot_pin",
          "settings": {
            "top_position": 35,
            "left_position": 45,
            "title": "Full Body Hourglass Shaper",
            "price": "$49.99",
            "compare_price": "$89.99"
          }
        },
        {
          "type": "hotspot_pin",
          "settings": {
            "top_position": 65,
            "left_position": 52,
            "title": "High-Waist Tummy Control Shorts",
            "price": "$39.99",
            "compare_price": "$69.99"
          }
        }
      ]
    }
  ]
}
{% endschema %}
