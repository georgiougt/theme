{% comment %}
  Trustpilot Reviews & Social Proof Grid (Shrine Pro Feature)
  ConvertStudio Theme
{% endcomment %}

<div class="trustpilot-reviews-section page-width color-custom-{{ section.id }}">
  <div class="tr-header text-center">
    <div class="tr-summary">
      <span class="tr-trustpilot-logo" style="color: {{ section.settings.star_color | default: '#00b67a' }};">
        {{- section.settings.header_logo_text | default: '★ Trustpilot' -}}
      </span>
      <div class="tr-stars" style="color: {{ section.settings.star_color | default: '#00b67a' }};">★★★★★</div>
      <span class="tr-score">
        Rated <strong>{{ section.settings.rating_score | default: '4.9 / 5.0' }}</strong> based on
        <strong>{{ section.settings.total_reviews_text | default: '2,480+ Reviews' }}</strong>
      </span>
    </div>
  </div>

  <div class="tr-grid">
    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        <div class="tr-card" {{ block.shopify_attributes }}>
          <div class="tr-card-stars" style="color: {{ section.settings.star_color | default: '#00b67a' }};">
            {%- assign rating = block.settings.rating | default: 5 -%}
            {%- for i in (1..rating) -%}★{%- endfor -%}
          </div>
          {%- if block.settings.title != blank -%}
            <h4 class="tr-card-title">"{{ block.settings.title }}"</h4>
          {%- endif -%}
          {%- if block.settings.quote != blank -%}
            <p class="tr-card-text">{{ block.settings.quote }}</p>
          {%- endif -%}
          <div class="tr-card-author">
            <strong>{{ block.settings.author | default: 'Verified Customer' }}</strong>
            {%- if block.settings.verified -%}
              <span class="tr-verified">✓ Verified Buyer</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <!-- Default Fallback Reviews if no blocks added yet -->
      <div class="tr-card">
        <div class="tr-card-stars" style="color: {{ section.settings.star_color | default: '#00b67a' }};">★★★★★</div>
        <h4 class="tr-card-title">"Invisible under my wedding dress!"</h4>
        <p class="tr-card-text">I was terrified of shapewear lines showing on my big day. ConvertStudio smoothed my belly completely and felt like second skin all night long!</p>
        <div class="tr-card-author">
          <strong>Jessica M.</strong> <span class="tr-verified">✓ Verified Buyer</span>
        </div>
      </div>
      <div class="tr-card">
        <div class="tr-card-stars" style="color: {{ section.settings.star_color | default: '#00b67a' }};">★★★★★</div>
        <h4 class="tr-card-title">"Zero rolling down!"</h4>
        <p class="tr-card-text">Every other shapewear I bought rolled down after 10 minutes. The silicone bands on this pair actually WORK. Ordering 2 more pairs right now!</p>
        <div class="tr-card-author">
          <strong>Amanda K.</strong> <span class="tr-verified">✓ Verified Buyer</span>
        </div>
      </div>
      <div class="tr-card">
        <div class="tr-card-stars" style="color: {{ section.settings.star_color | default: '#00b67a' }};">★★★★★</div>
        <h4 class="tr-card-title">"Confidence boosted 100%"</h4>
        <p class="tr-card-text">Dropped 2 dress sizes instantly. My husband noticed immediately and I feel incredible wearing my favorite bodycon dresses again.</p>
        <div class="tr-card-author">
          <strong>Rachel T.</strong> <span class="tr-verified">✓ Verified Buyer</span>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

<style>
  .trustpilot-reviews-section {
    padding-block: 4rem;
  }

  .tr-header {
    margin-bottom: 2.5rem;
  }

  .tr-summary {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .tr-trustpilot-logo {
    font-size: 1.25rem;
    font-weight: 800;
  }

  .tr-stars {
    font-size: 1.5rem;
    letter-spacing: 2px;
  }

  .tr-score {
    font-size: 0.9375rem;
    color: #475569;
  }

  .tr-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media screen and (max-width: 850px) {
    .tr-grid {
      grid-template-columns: 1fr;
    }
  }

  .tr-card {
    background: #ffffff;
    padding: 1.75rem;
    border-radius: 14px;
    border: 1px solid #e2e8f0;
    box-shadow: 0 4px 20px rgba(15, 23, 42, 0.05);
    display: flex;
    flex-direction: column;
  }

  .tr-card-stars {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .tr-card-title {
    font-weight: 700;
    font-size: 1.05rem;
    color: #0f172a;
    margin: 0 0 0.5rem 0;
  }

  .tr-card-text {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #475569;
    flex-grow: 1;
    margin-bottom: 1.25rem;
  }

  .tr-card-author {
    font-size: 0.8125rem;
    color: #0f172a;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid #f1f5f9;
    padding-top: 0.85rem;
  }

  .tr-verified {
    color: #10b981;
    font-weight: 700;
  }
</style>

{% schema %}
{
  "name": "ConvertStudio: Trustpilot Reviews Grid",
  "tag": "section",
  "class": "section-trustpilot-reviews",
  "settings": [
    {
      "type": "header",
      "content": "Section Header Settings"
    },
    {
      "type": "text",
      "id": "header_logo_text",
      "label": "Logo Header Text",
      "default": "★ Trustpilot"
    },
    {
      "type": "text",
      "id": "rating_score",
      "label": "Overall Rating Score",
      "default": "4.9 / 5.0"
    },
    {
      "type": "text",
      "id": "total_reviews_text",
      "label": "Total Reviews Count Text",
      "default": "2,480+ Reviews"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star & Logo Accent Color",
      "default": "#00b67a"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Customer Review Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Review Headline",
          "default": "Invisible under my wedding dress!"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review Body",
          "default": "I was terrified of shapewear lines showing on my big day. ConvertStudio smoothed my belly completely and felt like second skin all night long!"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Customer Name",
          "default": "Jessica M."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show Verified Buyer Tag",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ConvertStudio: Trustpilot Reviews Grid",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "title": "Invisible under my wedding dress!",
            "quote": "I was terrified of shapewear lines showing on my big day. ConvertStudio smoothed my belly completely and felt like second skin all night long!",
            "author": "Jessica M.",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "title": "Zero rolling down!",
            "quote": "Every other shapewear I bought rolled down after 10 minutes. The silicone bands on this pair actually WORK. Ordering 2 more pairs right now!",
            "author": "Amanda K.",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "title": "Confidence boosted 100%",
            "quote": "Dropped 2 dress sizes instantly. My husband noticed immediately and I feel incredible wearing my favorite bodycon dresses again.",
            "author": "Rachel T.",
            "verified": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
