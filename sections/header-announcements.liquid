

{% if section.blocks.size > 1 %}
  <script
    src="{{ 'announcement-bar.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>
{% endif %}

{% render 'contrast-override', background_color: section.settings.background_color, section_id: section.id %}

{%- if section.settings.enable_marquee -%}
  <div
    class="announcement-marquee spacing-style section section--full-width color-custom-{{ section.id }}"
    style="{% render 'spacing-padding', settings: section.settings %}; --marquee-speed: {{ section.settings.marquee_speed | default: 20 }}s; --border-bottom-width: {{ section.settings.divider_width }}px;{% if section.settings.divider_color != blank %} --color-border: {{ section.settings.divider_color }};{% endif %}"
  >
    <div class="announcement-marquee__track">
      <div class="announcement-marquee__content">
        <span class="announcement-marquee__item">🚚 {{ section.settings.marquee_text | default: "FREE SHIPPING WORLDWIDE ON ALL ORDERS OVER $50" }}</span>
        <span class="announcement-marquee__dot">•</span>
        <span class="announcement-marquee__item">⚡ 30-DAY EASY RETURNS & MONEY-BACK GUARANTEE</span>
        <span class="announcement-marquee__dot">•</span>
        <span class="announcement-marquee__item">🚀 EXPRESS 2-DAY WORLDWIDE DELIVERY</span>
        <span class="announcement-marquee__dot">•</span>
      </div>
      <div class="announcement-marquee__content" aria-hidden="true">
        <span class="announcement-marquee__item">🚚 {{ section.settings.marquee_text | default: "FREE SHIPPING WORLDWIDE ON ALL ORDERS OVER $50" }}</span>
        <span class="announcement-marquee__dot">•</span>
        <span class="announcement-marquee__item">⚡ 30-DAY EASY RETURNS & MONEY-BACK GUARANTEE</span>
        <span class="announcement-marquee__dot">•</span>
        <span class="announcement-marquee__item">🚀 EXPRESS 2-DAY WORLDWIDE DELIVERY</span>
        <span class="announcement-marquee__dot">•</span>
      </div>
    </div>
  </div>
{%- else -%}
  <aside
    class="announcement-bar spacing-style section section--{{ section.settings.section_width }} color-custom-{{ section.id }}"
    style="{% render 'spacing-padding', settings: section.settings %}; --border-bottom-width: {{ section.settings.divider_width }}px;{% if section.settings.divider_color != blank %} --color-border: {{ section.settings.divider_color }};{% endif %}"
  >
    {% liquid
      assign autoplay = false
      assign show_arrows = false
      if section.blocks.size > 1
        assign autoplay = true
        assign show_arrows = true
      endif
    %}

    <announcement-bar-component
      class="announcement-bar__slider"
      {% if autoplay == true %}
        autoplay="{{ section.settings.speed }}" aria-live="polite"
      {% endif %}
    >
      {% if show_arrows %}
        {% render 'slideshow-arrows', icon_style: 'chevron' %}
      {% endif %}

      <div class="announcement-bar__slides">
        {% content_for 'blocks' %}
      </div>
    </announcement-bar-component>
  </aside>
{%- endif -%}

{% stylesheet %}
  .announcement-bar {
    border-block-end: var(--border-bottom-width) solid var(--color-border);
  }

  .announcement-bar__slider {
    display: flex;
    flex-direction: row;
    align-items: center;
    position: relative;

    @media screen and (max-width: 749px) {
      grid-column: 1 / -1;
    }
  }

  .announcement-bar__slides {
    display: grid;
    grid: [stack] auto / [stack] auto;
    width: calc(100% - var(--button-size) * 2);
    max-width: 680px;
    margin-inline: auto;
  }

  .announcement-bar__slides > * {
    grid-area: stack;
  }

  .announcement-bar__slide {
    transition: opacity 0.5s ease-in-out, visibility 0.5s ease-in-out;
    content-visibility: visible;

    &[aria-hidden='true'] {
      opacity: 0;
      visibility: hidden;
    }
  }

  .announcement-bar__slider slideshow-arrows {
    padding: 0;
    mix-blend-mode: normal;
  }

  .announcement-bar__slider slideshow-arrows .slideshow-control {
    color: var(--color-foreground);
  }

  .announcement-bar__slider .slideshow-control {
    display: flex;
    padding: 0;
    width: var(--button-size);
    height: var(--button-size);
    align-items: center;
    justify-content: center;
    opacity: 1;
    animation: none;

    @media screen and (min-width: 750px) {
      --slideshow-control-offset: calc((var(--button-size) - var(--icon-size-xs)) / 2);

      .section--page-width &.slideshow-control--previous {
        transform: translateX(var(--slideshow-control-offset));
      }
    }
  }

  .announcement-bar__slider .slideshow-control .svg-wrapper {
    width: var(--icon-size-xs);
    height: var(--icon-size-xs);
  }

  .announcement-bar__slide {
    place-content: center;
  }

  .announcement-bar__text:first-child {
    margin: 0;
  }

  .announcement-bar__link {
    position: absolute;
    inset: 0;
  }

  .announcement-marquee {
    overflow: hidden;
    white-space: nowrap;
    width: 100%;
    display: flex;
    align-items: center;
    background: rgba(0, 0, 0, 0.35) !important;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-block-end: 1px solid rgba(255, 255, 255, 0.15);
    padding-block: 0.5rem;
    position: relative;
    z-index: 10;
  }

  .announcement-marquee__track {
    display: flex;
    width: max-content;
    animation: marquee-infinite var(--marquee-speed, 20s) linear infinite;
  }

  .announcement-marquee__track:hover {
    animation-play-state: paused;
  }

  .announcement-marquee__content {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding-inline-end: 2.5rem;
  }

  .announcement-marquee__item {
    font-family: 'Hunter', sans-serif;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #ffffff !important;
  }

  .announcement-marquee__dot {
    color: #ffffff !important;
    opacity: 0.8;
    font-weight: bold;
  }

  @keyframes marquee-infinite {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.announcement_bar",
  "blocks": [
    {
      "type": "_announcement"
    }
  ],
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_marquee",
      "label": "Enable Continuous Scrolling Marquee",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "marquee_text",
      "label": "Marquee Announcement Text",
      "default": "FREE SHIPPING WORLDWIDE ON ALL ORDERS OVER $50"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "label": "Marquee Scroll Duration (Seconds)",
      "min": 5,
      "max": 40,
      "step": 1,
      "unit": "s",
      "default": 20
    },
    {
      "type": "range",
      "id": "speed",
      "label": "t:settings.scroll_speed",
      "min": 2,
      "max": 10,
      "default": 5,
      "unit": "sec"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.section_width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "t:settings.divider_thickness",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "t:settings.divider_color",
      "placeholder": "t:settings.default",
      "visible_if": "{{ section.settings.divider_width > 0 }}"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "t:names.announcement_bar",
      "blocks": {
        "announcement_1": {
          "type": "_announcement"
        }
      },
      "block_order": ["announcement_1"]
    }
  ]
}
{% endschema %}
